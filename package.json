{
  "name": "dfo-storybook-10",
  "private": true,
  "version": "10.0.0-beta",
  "type": "module",
  "scripts": {
    "delete:fonts": "shx rm -rf public/fonts",
    "copy:fonts": "shx rm -rf public/fonts && shx mkdir -p public/fonts && copyfiles -u 2 \"node_modules/source-sans/WOFF*/**/*\" public/fonts && copyfiles -u 2 \"node_modules/source-serif/WOFF*/**/*\" public/fonts",
    "prebuild": "ts-node scripts/generate-version.ts",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "npm run prebuild && npm run copy:fonts && storybook dev || echo 'Failed to copy fonts'",
    "build-storybook": "npm run copy:fonts && storybook build || echo 'Failed to copy fonts'"
  },
  "dependencies": {
    "classnames": "2.5.1",
    "foundation-sites": "6.9.0",
    "js-beautify": "1.15.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-textarea-autosize": "8.5.9",
    "source-sans": "3.52.0",
    "source-serif": "4.5.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.1.2",
    "@eslint/js": "10.0.1",
    "@storybook/addon-a11y": "10.3.6",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/addon-links": "10.3.6",
    "@storybook/addon-vitest": "10.3.6",
    "@storybook/react-vite": "10.3.6",
    "@types/classnames": "2.3.4",
    "@types/js-beautify": "1.14.3",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@types/react-textarea-autosize": "8.0.0",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "copyfiles": "2.4.1",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-storybook": "10.3.6",
    "globals": "17.6.0",
    "playwright": "1.59.1",
    "react-syntax-highlighter": "16.1.1",
    "sass": "1.99.0",
    "shx": "0.4.0",
    "storybook": "10.3.6",
    "ts-node": "10.9.2",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.10",
    "vite-plugin-sass-dts": "1.3.37",
    "vite-plugin-style-import": "2.0.0",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.5"
  },
  "overrides": {
    "storybook": {
      "@vitest/expect": "4.1.3"
    },
    "@vitest/expect": "4.1.3"
  }
}
